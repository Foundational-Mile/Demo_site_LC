---
import { withBase } from '../utils/paths';

interface Props {
  eyebrow?: string;
  title?: string;
  text?: string;
  leftPillars?: string[];
  poster: string;
  videoAlt: string;
  videoSrc?: string;
  primaryCta?: { label: string; href: string };
  secondaryCta?: { label: string; href: string };
  serviceSummary?: string;
  location?: string;
}

const {
  eyebrow,
  title = '',
  text = '',
  leftPillars = [],
  poster,
  videoAlt,
  videoSrc = '/videos/hero-home.mp4',
  primaryCta,
  secondaryCta,
  serviceSummary,
  location
} = Astro.props;

const resolvedPoster = withBase(poster);
const resolvedVideoSrc = withBase(videoSrc);
---

<section class="full-hero surface-dark" aria-label="Homepage hero">
  <div class="hero-media">
    <video class="hero-video" autoplay muted loop playsinline poster={resolvedPoster} preload="metadata" aria-label={videoAlt}>
      <source src={resolvedVideoSrc} type="video/mp4" />
    </video>
    <div class="hero-scrim"></div>
  </div>

  <div class="hero-content">
    <div class="container hero-layout">
      {leftPillars.length > 0 ? (
        <div class="pillar-wrap" aria-label="Faith pillars">
          <h1 class="pillar-heading">
            {leftPillars.map((pillar) => (
              <span class="pillar-line">{pillar}</span>
            ))}
          </h1>
        </div>
      ) : (
        <div class="stack hero-stack">
          {eyebrow && <span class="eyebrow">{eyebrow}</span>}
          {title && <h1 class="title-xl">{title}</h1>}
          {text && <p class="lead">{text}</p>}

          {(primaryCta || secondaryCta) && (
            <div class="cluster">
              {primaryCta && <a class="btn btn-primary" href={withBase(primaryCta.href)}>{primaryCta.label}</a>}
              {secondaryCta && <a class="btn btn-secondary" href={withBase(secondaryCta.href)}>{secondaryCta.label}</a>}
            </div>
          )}
        </div>
      )}
    </div>
    {(serviceSummary || location) && (
      <div class="hero-frame">
        <div class="container frame-inner">
          {serviceSummary && (
            <p>
              <strong>Service Times</strong>
              <span>{serviceSummary}</span>
            </p>
          )}
          {location && (
            <p>
              <strong>Location</strong>
              <span>{location}</span>
            </p>
          )}
        </div>
      </div>
    )}
  </div>
  
  <div class="sr-only">
    {title}
    {text}
  </div>
</section>

<style>
  .full-hero {
    position: relative;
    min-height: clamp(480px, 72vh, 860px);
  }

  .hero-media,
  .hero-video,
  .hero-scrim,
  .hero-content {
    position: absolute;
    inset: 0;
  }

  .hero-video {
    width: 100%;
    height: 100%;
    object-fit: cover;
    background: #0f1219;
  }

  .hero-scrim {
    background:
      linear-gradient(180deg, rgba(8, 9, 12, 0.2) 0%, rgba(8, 9, 12, 0.6) 72%, rgba(8, 9, 12, 0.85) 100%),
      radial-gradient(circle at 78% 18%, rgba(255, 255, 255, 0.1), transparent 40%);
  }

  .hero-content {
    display: grid;
    align-items: stretch;
    z-index: 1;
  }

  .hero-layout {
    display: grid;
    align-items: center;
    min-height: 100%;
    padding-bottom: clamp(6.2rem, 10vw, 9rem);
  }

  .hero-stack {
    padding-bottom: clamp(2rem, 6vw, 4rem);
    max-width: 52ch;
  }

  .pillar-wrap {
    max-width: 28ch;
  }

  .pillar-heading {
    margin: 0;
    display: grid;
    gap: 0.35rem;
  }

  .pillar-line {
    display: block;
    font-family: 'Barlow Condensed', 'Barlow', sans-serif;
    font-size: clamp(2rem, 4.4vw, 3.8rem);
    font-style: italic;
    font-weight: 800;
    line-height: 0.98;
    letter-spacing: 0.02em;
    color: #f4f7fc;
    text-shadow: 0 5px 22px rgba(0, 0, 0, 0.34);
  }

  .hero-frame {
    position: absolute;
    left: 0;
    right: 0;
    bottom: 0;
    border-top: 1px solid rgba(255, 255, 255, 0.18);
    background: rgba(10, 12, 17, 0.58);
    backdrop-filter: blur(7px);
    padding: 0.95rem 0;
  }

  .frame-inner {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.9rem;
  }

  .frame-inner p {
    margin: 0;
    display: grid;
    gap: 0.18rem;
    color: #e6edf8;
    font-size: 0.94rem;
  }

  .frame-inner strong {
    font-size: 0.74rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #5d8ff2;
  }

  .full-hero .lead {
    color: #e4eaf5;
  }

  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  @media (max-width: 740px) {
    .full-hero {
      min-height: 520px;
    }

    .pillar-wrap {
      max-width: 20ch;
      gap: 0.35rem;
    }

    .frame-inner {
      grid-template-columns: 1fr;
    }

    .frame-inner p {
      font-size: 0.88rem;
    }
  }
</style>
