---
import { churchMeta, footerLinks } from '../data/site';
import { withBase } from '../utils/paths';
---

<footer class="site-footer surface-ink">
  <div class="container footer-grid">
    <div class="stack-lg">
      <h2 class="title-md">{churchMeta.name}</h2>
      <p>{churchMeta.tagline}</p>
      <ul class="stack-sm contact-list">
        <li>{churchMeta.address}</li>
        <li>{churchMeta.phone}</li>
      </ul>
      <a href={withBase('/plan-your-visit')} class="btn btn-primary">First-Time Guide</a>
    </div>

    <div>
      <h3>Explore</h3>
      <ul class="stack-sm">
        {footerLinks.explore.map((link) => (
          <li><a href={withBase(link.href)}>{link.label}</a></li>
        ))}
      </ul>
    </div>

    <div>
      <h3>Connect</h3>
      <ul class="stack-sm">
        {footerLinks.connect.map((link) => (
          <li><a href={withBase(link.href)}>{link.label}</a></li>
        ))}
      </ul>
    </div>

    <div>
      <h3>Resources</h3>
      <ul class="stack-sm">
        {footerLinks.resources.map((link) => (
          <li><a href={withBase(link.href)}>{link.label}</a></li>
        ))}
      </ul>
    </div>
  </div>
  <div class="container footer-bottom">
    <p>© {new Date().getFullYear()} Limitless Church. All rights reserved.</p>
  </div>
</footer>

<style>
  .site-footer {
    padding: 2.4rem 0 1rem;
    margin-top: clamp(2.2rem, 4vw, 3.8rem);
    border-top: 1px solid rgba(255, 255, 255, 0.14);
  }

  .site-footer p,
  .site-footer li,
  .site-footer a {
    color: #c1c8d4;
    font-size: 0.86rem;
    line-height: 1.4;
  }

  .site-footer a:hover,
  .site-footer a:focus-visible {
    color: #ffffff;
  }

  .footer-grid {
    display: grid;
    gap: 1.1rem;
    grid-template-columns: 1.35fr repeat(3, minmax(0, 1fr));
    padding-bottom: 1.45rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.14);
  }

  .contact-list {
    font-size: 0.82rem;
  }

  .site-footer h2 {
    font-size: 1.55rem;
    letter-spacing: 0.05em;
  }

  .site-footer h3 {
    margin-bottom: 0.6rem;
    font-size: 0.9rem;
    letter-spacing: 0.08em;
    color: #f7f9fc;
    position: relative;
    padding-bottom: 0.34rem;
  }

  .site-footer h3::after {
    content: '';
    position: absolute;
    left: 0;
    bottom: 0;
    width: 2.1rem;
    height: 0.1rem;
    background: #2a6fe8;
  }

  .footer-bottom {
    padding-top: 0.9rem;
    font-size: 0.74rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  @media (max-width: 900px) {
    .footer-grid {
      grid-template-columns: 1fr 1fr;
    }
  }

  @media (max-width: 650px) {
    .footer-grid {
      grid-template-columns: 1fr;
    }

    .site-footer {
      padding-top: 2.8rem;
    }
  }
</style>
