---
import { navLinks } from '../data/site';
import { withBase, withoutBase } from '../utils/paths';

interface Props {
  pathname: string;
}

const { pathname } = Astro.props;

const normalizePath = (value: string) => {
  if (value.length > 1 && value.endsWith('/')) return value.slice(0, -1);
  return value;
};

const currentPath = normalizePath(withoutBase(pathname));

const isActive = (href: string) => {
  const target = normalizePath(href);
  if (target === '/') return currentPath === '/';
  return currentPath === target || currentPath.startsWith(`${target}/`);
};

const isLinkActive = (link: (typeof navLinks)[number]) => {
  if (isActive(link.href)) return true;
  return link.children?.some((child) => isActive(child.href)) ?? false;
};
---

<header class="site-header">
  <div class="container header-inner">
    <a href={withBase('/')} class="brand">
      <span>Limitless</span>
      <small>Church</small>
    </a>

    <nav class="desktop-nav" aria-label="Main">
      <ul>
        {navLinks.map((link) => {
          const hasChildren = (link.children?.length ?? 0) > 0;
          const active = isLinkActive(link);

          return (
            <li class={`nav-item ${hasChildren ? 'has-children' : ''}`}>
              <a href={withBase(link.href)} class={active ? 'active' : ''}>
                {link.label}
                {hasChildren && <span class="caret" aria-hidden="true">▾</span>}
              </a>

              {hasChildren && (
                <ul class="dropdown" aria-label={`${link.label} subpages`}>
                  {link.children?.map((child) => (
                    <li>
                      <a href={withBase(child.href)} class={isActive(child.href) ? 'active' : ''}>
                        {child.label}
                      </a>
                    </li>
                  ))}
                </ul>
              )}
            </li>
          );
        })}
      </ul>
    </nav>

    <a class="btn btn-primary desktop-visit" href={withBase('/plan-your-visit')}>I'm New</a>

    <details class="mobile-nav">
      <summary aria-label="Open navigation menu">Menu</summary>
      <nav aria-label="Mobile">
        <ul>
          {navLinks.map((link) => {
            const hasChildren = (link.children?.length ?? 0) > 0;
            const active = isLinkActive(link);

            if (!hasChildren) {
              return (
                <li>
                  <a href={withBase(link.href)} class={active ? 'active' : ''}>{link.label}</a>
                </li>
              );
            }

            return (
              <li class="mobile-group">
                <details open={active}>
                  <summary class={active ? 'active' : ''}>{link.label}</summary>
                  <div class="mobile-group-links">
                    {link.children?.map((child) => (
                      <a href={withBase(child.href)} class={isActive(child.href) ? 'active' : ''}>
                        {child.label}
                      </a>
                    ))}
                  </div>
                </details>
              </li>
            );
          })}
        </ul>
        <a class="btn btn-primary" href={withBase('/plan-your-visit')}>I'm New</a>
      </nav>
    </details>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 30;
    background: rgba(9, 11, 14, 0.95);
    backdrop-filter: blur(10px);
    border-bottom: 1px solid rgba(255, 255, 255, 0.1);
  }

  .header-inner {
    min-height: 3.75rem;
    display: flex;
    align-items: center;
    gap: 0.7rem;
  }

  .brand {
    display: grid;
    line-height: 1;
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 700;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: #f3f4f7;
  }

  .brand span {
    font-size: 1.25rem;
  }

  .brand small {
    font-size: 0.64rem;
    text-transform: uppercase;
    letter-spacing: 0.16em;
    color: #adb6c4;
    margin-top: 0.08rem;
  }

  .desktop-nav {
    margin-left: auto;
  }

  .desktop-nav > ul {
    display: flex;
    align-items: center;
    gap: 0.12rem;
    flex-wrap: nowrap;
  }

  .nav-item {
    position: relative;
    display: block;
  }

  .desktop-nav a {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 0.83rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.055em;
    color: #c6ccd6;
    padding: 0.34rem 0.5rem;
    border-radius: 0.2rem;
    white-space: nowrap;
    transition: color 160ms ease, background-color 160ms ease, box-shadow 160ms ease;
  }

  .nav-item > a {
    display: inline-flex;
    align-items: center;
    gap: 0.28rem;
  }

  .caret {
    font-size: 0.6rem;
    opacity: 0.82;
    transform: translateY(-1px);
  }

  .desktop-nav a:hover,
  .desktop-nav a:focus-visible,
  .desktop-nav a.active {
    color: #ffffff;
    background: rgba(255, 255, 255, 0.08);
    box-shadow: inset 0 -2px 0 #2a6fe8;
  }

  .dropdown {
    position: absolute;
    left: 0;
    top: calc(100% - 1px);
    min-width: 12.8rem;
    padding: 0.45rem;
    display: grid;
    gap: 0.12rem;
    background: #141922;
    border: 1px solid rgba(255, 255, 255, 0.12);
    border-top: 2px solid #2a6fe8;
    border-radius: 0.45rem;
    box-shadow: var(--shadow-md);
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
    transition: opacity 120ms ease, visibility 120ms ease;
    z-index: 40;
  }

  .dropdown a {
    display: block;
    font-size: 0.78rem;
    letter-spacing: 0.05em;
    color: #d4dbe8;
    padding: 0.45rem 0.52rem;
    border-radius: 0.32rem;
  }

  .dropdown a:hover,
  .dropdown a:focus-visible,
  .dropdown a.active {
    background: rgba(255, 255, 255, 0.08);
    color: #ffffff;
    box-shadow: none;
  }

  .nav-item.has-children:hover > .dropdown,
  .nav-item.has-children:focus-within > .dropdown {
    opacity: 1;
    visibility: visible;
    pointer-events: auto;
  }

  .desktop-visit {
    margin-left: 0.35rem;
    font-size: 0.84rem;
    padding: 0.5rem 0.74rem;
    box-shadow: none;
  }

  .mobile-nav {
    display: none;
    margin-left: auto;
    position: relative;
  }

  .mobile-nav > summary {
    list-style: none;
    cursor: pointer;
    font-weight: 700;
    font-family: 'Barlow Condensed', sans-serif;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: #eef1f6;
    padding: 0.4rem 0.58rem;
    border: 1px solid rgba(255, 255, 255, 0.24);
    border-radius: 0.25rem;
    font-size: 0.84rem;
    background: rgba(255, 255, 255, 0.07);
  }

  .mobile-nav > summary::-webkit-details-marker {
    display: none;
  }

  .mobile-nav nav {
    position: absolute;
    right: 0;
    top: calc(100% + 0.5rem);
    width: min(18rem, calc(100vw - 1.4rem));
    background: #141922;
    border: 1px solid rgba(255, 255, 255, 0.12);
    border-radius: 0.5rem;
    box-shadow: var(--shadow-md);
    padding: 0.8rem;
    display: grid;
    gap: 0.85rem;
  }

  .mobile-nav ul {
    display: grid;
    gap: 0.2rem;
  }

  .mobile-nav a {
    display: block;
    padding: 0.5rem 0.56rem;
    border-radius: 0.35rem;
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 700;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: #d5dbe6;
  }

  .mobile-nav a.active,
  .mobile-nav a:hover,
  .mobile-nav a:focus-visible {
    background: rgba(255, 255, 255, 0.08);
    color: #ffffff;
  }

  .mobile-group details {
    border-radius: 0.35rem;
    border: 1px solid rgba(255, 255, 255, 0.1);
    background: rgba(255, 255, 255, 0.03);
    padding: 0.2rem;
  }

  .mobile-group summary {
    list-style: none;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.4rem 0.45rem;
    border-radius: 0.28rem;
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 0.84rem;
    font-weight: 700;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: #d5dbe6;
    white-space: nowrap;
  }

  .mobile-group summary::-webkit-details-marker {
    display: none;
  }

  .mobile-group summary::after {
    content: '▾';
    font-size: 0.62rem;
    opacity: 0.8;
    transition: transform 120ms ease;
  }

  .mobile-group details[open] summary::after {
    transform: rotate(180deg);
  }

  .mobile-group summary.active,
  .mobile-group summary:hover,
  .mobile-group summary:focus-visible {
    background: rgba(255, 255, 255, 0.07);
    color: #ffffff;
  }

  .mobile-group-links {
    display: grid;
    gap: 0.14rem;
    margin-top: 0.2rem;
    padding-left: 0.3rem;
    border-left: 1px solid rgba(255, 255, 255, 0.16);
  }

  .mobile-group-links a {
    font-size: 0.76rem;
    letter-spacing: 0.05em;
    color: #cfd6e3;
    padding: 0.42rem 0.46rem;
  }

  @media (max-width: 1080px) {
    .desktop-nav,
    .desktop-visit {
      display: none;
    }

    .mobile-nav {
      display: block;
    }
  }
</style>
