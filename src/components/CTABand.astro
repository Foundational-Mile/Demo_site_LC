---
interface Props {
  eyebrow?: string;
  title: string;
  text: string;
  primary: { label: string; href: string };
  secondary?: { label: string; href: string };
  dark?: boolean;
}

const { eyebrow, title, text, primary, secondary, dark = true } = Astro.props;
---

<section class="section-tight">
  <div class={`container cta-band ${dark ? 'dark' : 'light'}`}>
    <div class="stack">
      {eyebrow && <span class="eyebrow">{eyebrow}</span>}
      <h2 class="title-lg">{title}</h2>
      <p class="lead">{text}</p>
    </div>
    <div class="cluster">
      <a class="btn btn-primary" href={primary.href}>{primary.label}</a>
      {secondary && <a class="btn btn-secondary" href={secondary.href}>{secondary.label}</a>}
    </div>
  </div>
</section>

<style>
  .cta-band {
    border-radius: var(--radius-lg);
    padding: clamp(1rem, 3.2vw, 1.8rem);
    display: grid;
    gap: 0.82rem;
    align-items: center;
    grid-template-columns: 1.1fr auto;
    border-top: 3px solid #2a6fe8;
  }

  .cta-band.dark {
    background: radial-gradient(circle at right top, rgba(255, 255, 255, 0.12), rgba(12, 15, 22, 1) 40%);
    color: var(--text);
    border: 1px solid rgba(255, 255, 255, 0.16);
    border-top: 3px solid #5d8ff2;
  }

  .cta-band.dark h2,
  .cta-band.dark p {
    color: var(--text);
  }

  .cta-band.light {
    background: #fff;
    border: 1px solid rgba(16, 18, 24, 0.13);
  }

  @media (max-width: 880px) {
    .cta-band {
      grid-template-columns: 1fr;
    }
  }
</style>
