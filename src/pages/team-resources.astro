---
import BaseLayout from '../layouts/BaseLayout.astro';

// Unlisted direct-link demo: this route is noindexed, but it is not private/authenticated.
Astro.response.headers.set('X-Robots-Tag', 'noindex, nofollow');

const heroActions = [
  { label: 'View Small Group Resources', href: '#small-group-leaders' },
  { label: 'Volunteer Guides', href: '#featured-resources' },
  { label: 'Prayer Team Tools', href: '#prayer-team' }
];

const quickAccessAreas = [
  {
    id: 'small-group-leaders',
    mark: 'SG',
    title: 'Small Group Leaders',
    description: 'Simple planning tools and discussion support for healthy, consistent group gatherings.',
    links: [
      { label: 'Leader Start Guide', href: '#leader-start-guide' },
      { label: 'Weekly Discussion Prompts', href: '#weekly-discussion-prompts' },
      { label: 'Attendance Snapshot Template', href: '#attendance-snapshot-template' }
    ]
  },
  {
    id: 'hospitality-team',
    mark: 'HT',
    title: 'Hospitality Team',
    description: 'Warm welcome resources to help every guest feel seen from parking lot to auditorium.',
    links: [
      { label: 'Guest Welcome Flow', href: '#guest-welcome-flow' },
      { label: 'Lobby Readiness Checklist', href: '#lobby-readiness-checklist' },
      { label: 'Sunday Host Talking Points', href: '#sunday-host-talking-points' }
    ]
  },
  {
    id: 'prayer-team',
    mark: 'PT',
    title: 'Prayer Team',
    description: 'Guides that keep prayer moments focused, compassionate, and aligned with team values.',
    links: [
      { label: 'Prayer Team Best Practices', href: '#prayer-team-best-practices' },
      { label: 'Response Card Follow-Up', href: '#response-card-follow-up' },
      { label: 'Prayer Request Form', href: '#prayer-request-form' }
    ]
  },
  {
    id: 'kids-ministry-volunteers',
    mark: 'KM',
    title: 'Kids Ministry Volunteers',
    description: 'Family-friendly tools for safe check-in, secure handoff, and joyful classroom moments.',
    links: [
      { label: 'Kids Check-In Overview', href: '#kids-check-in-overview' },
      { label: 'Classroom Rhythm Guide', href: '#classroom-rhythm-guide' },
      { label: 'Volunteer Welcome Packet', href: '#volunteer-welcome-packet' }
    ]
  },
  {
    id: 'follow-up-team',
    mark: 'FU',
    title: 'Follow-Up Team',
    description: 'Practical follow-up templates to connect with first-time guests in a timely, caring way.',
    links: [
      { label: 'Guest Follow-Up Checklist', href: '#guest-follow-up-checklist' },
      { label: 'First Visit Email Script', href: '#first-visit-email-script' },
      { label: 'Next Steps Handoff Notes', href: '#next-steps-handoff-notes' }
    ]
  },
  {
    id: 'sunday-service-team',
    mark: 'SS',
    title: 'Sunday Service Team',
    description: 'Quick references to help teams prepare spaces, welcome people, and run Sunday smoothly.',
    links: [
      { label: 'Sunday Team Setup Guide', href: '#sunday-team-setup-guide' },
      { label: 'Service Run Sheet Sample', href: '#service-run-sheet-sample' },
      { label: 'Post-Service Reset List', href: '#post-service-reset-list' }
    ]
  }
];

const featuredResources = [
  { title: 'Small Group Discussion Guide (PDF)', href: '#small-group-discussion-guide-pdf', type: 'Guide' },
  { title: 'First-Time Guest Follow-Up Checklist', href: '#first-time-guest-follow-up-checklist', type: 'Checklist' },
  { title: 'Prayer Request Submission Form', href: '#prayer-request-submission-form', type: 'Form' },
  { title: 'Volunteer Welcome Packet', href: '#volunteer-welcome-packet-file', type: 'Packet' },
  { title: 'Sunday Team Setup Guide', href: '#sunday-team-setup-guide-file', type: 'Guide' },
  { title: 'Event Planning Request Form', href: '#event-planning-request-form', type: 'Form' }
];

const weekAtGlance = [
  { label: 'Sunday Service', value: '9:00 AM and 11:00 AM' },
  { label: 'Volunteer Huddle', value: '8:15 AM' },
  { label: 'New Series', value: 'Faith That Moves' },
  { label: 'Small Group Focus', value: 'Prayer and Encouragement' },
  { label: 'Monthly Serve Day', value: 'April 27' }
];

const teamContacts = [
  {
    team: 'Groups + Leaders',
    email: 'groups@churchname.org',
    support: 'Questions about group resources, discussion guides, and leader onboarding.'
  },
  {
    team: 'Serve Team',
    email: 'serve@churchname.org',
    support: 'Help with volunteer pathways, Sunday serving, and role-specific support.'
  },
  {
    team: 'Prayer Team',
    email: 'prayer@churchname.org',
    support: 'Support for prayer resources, prayer care workflow, and request routing.'
  }
];

const downloadsAndForms = [
  { title: 'Leader Guide PDF', href: '#leader-guide-pdf' },
  { title: 'Volunteer Handbook', href: '#volunteer-handbook' },
  { title: 'Kids Check-In Overview', href: '#kids-check-in-overview-file' },
  { title: 'Prayer Team Best Practices', href: '#prayer-team-best-practices-file' },
  { title: 'Event Request Form', href: '#event-request-form-file' }
];
---

<BaseLayout
  title="Team Resources | Limitless Church"
  description="Direct-link ministry resource hub demo with public-safe content for leaders and volunteers."
  noindex={true}
>
  <!-- Unlisted route for direct sharing only; this is not private access control. -->
  <section class="section surface-dark resource-hero">
    <div class="container hero-layout">
      <div class="stack-lg">
        <div class="stack-sm">
          <span class="eyebrow">Leader Hub</span>
          <h1 class="title-xl">Team Resources</h1>
          <p class="lead">
            A clean, direct-link resource page for ministry teams. It is easy to share, easy to update,
            and still aligned with the church brand.
          </p>
        </div>

        <p class="hero-note">
          This demo page includes general, public-safe ministry resources only.
        </p>

        <div class="hero-actions">
          {heroActions.map((action) => (
            <a class="btn btn-primary" href={action.href}>{action.label}</a>
          ))}
        </div>
      </div>

      <aside class="safety-note" aria-label="Resource safety note">
        <p class="kicker">Direct Link Page</p>
        <h2 class="title-md">Shared By URL, Not Hidden Security</h2>
        <p>
          This page demonstrates a practical resource hub that teams can use without publishing sensitive data.
          Keep all files and links suitable for public viewing.
        </p>
      </aside>
    </div>
  </section>

  <section class="section surface-white">
    <div class="container stack-lg">
      <div class="section-heading stack-sm">
        <span class="eyebrow">Quick Access</span>
        <h2 class="title-lg">Resource Areas</h2>
        <p class="lead">
          Each area can hold starter guides, checklists, and forms that help teams serve consistently.
        </p>
      </div>

      <div class="grid grid-3 quick-access-grid">
        {quickAccessAreas.map((area) => (
          <article id={area.id} class="card resource-card">
            <div class="stack-sm">
              <div class="resource-title-row">
                <span class="team-mark" aria-hidden="true">{area.mark}</span>
                <h3 class="title-md">{area.title}</h3>
              </div>
              <p>{area.description}</p>
            </div>
            <div class="resource-links">
              {area.links.map((link) => (
                <a class="btn btn-ghost resource-link" href={link.href}>{link.label}</a>
              ))}
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section id="featured-resources" class="section surface-soft">
    <div class="container stack-lg">
      <div class="section-heading stack-sm">
        <span class="eyebrow">Featured Resources</span>
        <h2 class="title-lg">Commonly Used Tools</h2>
        <p class="lead">Example files and forms teams can access quickly from one simple page.</p>
      </div>

      <ul class="featured-resource-list" aria-label="Featured team resources">
        {featuredResources.map((resource) => (
          <li class="featured-resource-item card">
            <div class="stack-sm">
              <span class="badge">{resource.type}</span>
              <h3>{resource.title}</h3>
            </div>
            <a class="btn btn-secondary" href={resource.href}>Open Demo Link</a>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <section class="section surface-white">
    <div class="container week-glance-shell">
      <div class="stack-sm">
        <span class="eyebrow">This Week At A Glance</span>
        <h2 class="title-lg">Quick Ministry Snapshot</h2>
        <p class="lead">A simple overview section teams can reference before Sunday.</p>
      </div>

      <ul class="week-list" aria-label="This week at a glance">
        {weekAtGlance.map((item) => (
          <li>
            <p class="kicker">{item.label}</p>
            <p class="week-value">{item.value}</p>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <section class="section surface-soft">
    <div class="container stack-lg">
      <div class="section-heading stack-sm">
        <span class="eyebrow">Team Help</span>
        <h2 class="title-lg">Need Support?</h2>
        <p class="lead">If you need help, reach out to the ministry team.</p>
      </div>

      <div class="grid grid-3 contact-grid">
        {teamContacts.map((contact) => (
          <article class="card contact-card">
            <h3>{contact.team}</h3>
            <a class="contact-email" href={`mailto:${contact.email}`}>{contact.email}</a>
            <p>{contact.support}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section surface-white">
    <div class="container stack-lg">
      <div class="section-heading stack-sm">
        <span class="eyebrow">Downloads + Forms</span>
        <h2 class="title-lg">Public-Safe Team Files</h2>
        <p class="lead">Demo resources below are placeholders and can be replaced with live files later.</p>
      </div>

      <ul class="download-list" aria-label="Demo downloads and forms">
        {downloadsAndForms.map((item) => (
          <li>
            <a href={item.href}>{item.title}</a>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <section class="section-tight surface-soft">
    <div class="container">
      <p class="footer-note">
        This page is shared by direct link and intentionally contains only public-safe ministry resources.
      </p>
    </div>
  </section>
</BaseLayout>

<style>
  .resource-hero {
    padding-top: clamp(4rem, 9vw, 6rem);
    background:
      radial-gradient(circle at 85% 10%, rgba(94, 144, 255, 0.24), transparent 45%),
      radial-gradient(circle at 20% 90%, rgba(42, 111, 232, 0.2), transparent 45%),
      linear-gradient(180deg, #12161f 0%, #0b0f15 100%);
  }

  .hero-layout {
    display: grid;
    grid-template-columns: 1.4fr 1fr;
    gap: clamp(1.2rem, 3vw, 2.4rem);
    align-items: stretch;
  }

  .hero-note {
    color: #d6def0;
    border-left: 3px solid rgba(120, 166, 255, 0.9);
    padding-left: 0.8rem;
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.72rem;
  }

  .hero-actions .btn {
    min-width: 13rem;
  }

  .safety-note {
    align-self: center;
    background: rgba(255, 255, 255, 0.06);
    border: 1px solid rgba(255, 255, 255, 0.18);
    border-radius: var(--radius-lg);
    padding: clamp(1rem, 2.4vw, 1.35rem);
    display: grid;
    gap: 0.75rem;
  }

  .safety-note p {
    color: #d6dced;
  }

  .section-heading {
    padding-bottom: 0.35rem;
    border-bottom: 1px solid rgba(16, 18, 24, 0.11);
  }

  .quick-access-grid {
    gap: 1rem;
  }

  .resource-card {
    padding: 1.05rem;
    display: grid;
    gap: 0.95rem;
    align-content: start;
  }

  .resource-card p {
    color: #57647a;
  }

  .resource-title-row {
    display: flex;
    align-items: center;
    gap: 0.68rem;
  }

  .team-mark {
    width: 2.1rem;
    height: 2.1rem;
    border-radius: 999px;
    display: grid;
    place-items: center;
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 700;
    font-size: 0.82rem;
    letter-spacing: 0.04em;
    color: #1650b1;
    background: #d7e5ff;
    border: 1px solid rgba(42, 111, 232, 0.35);
    flex: 0 0 auto;
  }

  .resource-links {
    display: grid;
    gap: 0.5rem;
  }

  .resource-link {
    justify-content: space-between;
    text-transform: none;
    letter-spacing: 0.015em;
    font-size: 0.9rem;
    padding: 0.56rem 0.7rem;
  }

  .resource-link::after {
    content: '>';
    font-weight: 700;
    color: #1d56b9;
  }

  .featured-resource-list {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.9rem;
  }

  .featured-resource-item {
    padding: 1rem;
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 0.8rem;
    align-items: center;
  }

  .featured-resource-item h3 {
    font-size: 1.36rem;
    line-height: 1.06;
  }

  .featured-resource-item .btn {
    white-space: nowrap;
  }

  .week-glance-shell {
    display: grid;
    gap: 1.15rem;
  }

  .week-list {
    display: grid;
    grid-template-columns: repeat(5, minmax(0, 1fr));
    gap: 0.75rem;
  }

  .week-list li {
    background: #ffffff;
    border: 1px solid rgba(16, 18, 24, 0.11);
    border-radius: var(--radius-md);
    padding: 0.85rem;
    min-height: 7.3rem;
  }

  .week-value {
    margin-top: 0.34rem;
    font-size: 1.02rem;
    font-weight: 600;
    color: #1f2938;
  }

  .contact-grid {
    gap: 0.9rem;
  }

  .contact-card {
    padding: 1rem;
    display: grid;
    gap: 0.64rem;
  }

  .contact-card p {
    color: #566276;
  }

  .contact-email {
    color: #1d56b9;
    font-weight: 700;
    border-bottom: 1px solid rgba(29, 86, 185, 0.2);
    width: fit-content;
    padding-bottom: 0.1rem;
  }

  .download-list {
    display: grid;
    gap: 0.6rem;
  }

  .download-list li {
    border: 1px solid rgba(16, 18, 24, 0.11);
    border-radius: var(--radius-md);
    background: #fff;
    overflow: hidden;
  }

  .download-list a {
    display: block;
    padding: 0.78rem 0.9rem;
    font-weight: 600;
    color: #1f2938;
    transition: background-color var(--transition), color var(--transition);
  }

  .download-list a:hover,
  .download-list a:focus-visible {
    background: #edf3ff;
    color: #144498;
  }

  .footer-note {
    color: #58667d;
    font-size: 0.95rem;
    border-top: 1px solid rgba(16, 18, 24, 0.12);
    padding-top: 1rem;
  }

  @media (max-width: 1080px) {
    .hero-layout {
      grid-template-columns: 1fr;
    }

    .week-list {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 820px) {
    .featured-resource-list,
    .contact-grid,
    .week-list {
      grid-template-columns: 1fr;
    }

    .featured-resource-item {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 700px) {
    .hero-actions {
      display: grid;
      grid-template-columns: 1fr;
    }

    .hero-actions .btn {
      min-width: 0;
      width: 100%;
    }
  }
</style>
