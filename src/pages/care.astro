---
import BaseLayout from '../layouts/BaseLayout.astro';
import HeroSection from '../components/HeroSection.astro';
import SectionIntro from '../components/SectionIntro.astro';
import FAQAccordion from '../components/FAQAccordion.astro';
import FormPlaceholder from '../components/FormPlaceholder.astro';
import CTABand from '../components/CTABand.astro';
import { careResources, careFaqs, testimonials } from '../data/content';
import { media } from '../data/media';
---

<BaseLayout title="Care | Limitless Church">
  <HeroSection
    eyebrow="Care + Prayer"
    title="Care and Prayer Support"
    text="If you are carrying something heavy, our team is here for you."
    image={media.heroes.care}
    imageAlt="Two people praying together"
    primaryCta={{ label: 'Request Prayer', href: '#care-form' }}
    secondaryCta={{ label: 'Talk To A Pastor', href: '#care-form' }}
  />

  <section class="section surface-white">
    <div class="container split">
      <div class="stack-lg">
        <SectionIntro
          eyebrow="Our Heart"
          title="Care is ministry, not a side program"
          text="At Limitless, we believe real church family shows up in hard moments. Care at our church is rooted in prayer, presence, and practical help."
        />
        <ul class="list-check">
          <li>Confidential prayer and pastoral support</li>
          <li>Compassionate follow-up with clear next steps</li>
          <li>Care pathways for grief, crisis, and life transitions</li>
        </ul>
      </div>
      <article class="card calm-note">
        <p>
          “When we were in a difficult season, our church family stepped in with prayer, meals, and encouragement we
          will never forget.”
        </p>
        <strong>{testimonials[2].name}</strong>
      </article>
    </div>
  </section>

  <section class="section surface-soft">
    <div class="container stack-lg">
      <SectionIntro
        eyebrow="Support Pathways"
        title="Ways we can care for you"
        text="Here are practical ways our team can walk with you right now."
      />
      <div class="grid grid-2">
        {careResources.map((resource) => (
          <article class="card resource-card">
            <h3>{resource.title}</h3>
            <p>{resource.summary}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section surface-white" id="care-form">
    <div class="container split">
      <div class="stack-lg">
        <SectionIntro
          eyebrow="Prayer Request"
          title="Share what you need prayer for"
          text="You can let us know as much or as little as you are comfortable sharing. We will follow up with care and confidentiality."
        />
        <FAQAccordion items={careFaqs} />
      </div>
      <FormPlaceholder
        title="Care + Prayer Request"
        description="Care intake section ready for Church Center form, custom CRM intake, or secure pastoral care workflow."
        buttonLabel="Send Prayer Request"
      />
    </div>
  </section>

  <CTABand
    eyebrow="Need Immediate Help?"
    title="Our team can connect you with support quickly."
    text="For urgent needs, call the church office directly and our pastoral team will guide next steps."
    primary={{ label: 'Call Church Office', href: 'tel:+14175219806' }}
    secondary={{ label: 'Email Care Team', href: 'mailto:care@limitless.church' }}
  />
</BaseLayout>

<style>
  .resource-card,
  .calm-note {
    padding: 1.2rem;
  }

  .resource-card {
    display: grid;
    gap: 0.6rem;
  }

  .resource-card p,
  .calm-note p {
    color: #55647d;
  }

  .calm-note {
    align-content: center;
    background: linear-gradient(180deg, #ffffff 0%, #f0f2f6 100%);
    border: 1px solid #d9dde4;
    display: grid;
    gap: 1rem;
  }

  .calm-note strong {
    color: #0f1115;
  }
</style>
