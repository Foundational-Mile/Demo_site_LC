---
import BaseLayout from '../layouts/BaseLayout.astro';
import HeroSection from '../components/HeroSection.astro';
import SectionIntro from '../components/SectionIntro.astro';
import CTABand from '../components/CTABand.astro';
import { beliefs } from '../data/content';
---

<BaseLayout title="The Essentials | Limitless Church">
  <HeroSection
    eyebrow="The Essentials"
    title="What We Believe"
    text="These biblical essentials shape our doctrine, teaching, and spiritual formation as a church."
    centered={true}
    textured={true}
    primaryCta={{ label: 'Back To About', href: '/about' }}
    secondaryCta={{ label: 'Read Our Values', href: '/about-values' }}
  />

  <section class="section surface-white">
    <div class="container stack-lg">
      <SectionIntro
        eyebrow="Doctrine"
        title="Core Convictions"
        text="Each essential below summarizes a foundational belief we hold with clarity and conviction."
      />
      <div class="grid grid-2 essentials-grid">
        {beliefs.map((belief) => (
          <article class="card essential-card">
            <h3>{belief.heading}</h3>
            <p>{belief.text}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <CTABand
    eyebrow="Questions?"
    title="Want to talk through what we believe?"
    text="Our pastors would love to help you process faith, scripture, and next steps."
    primary={{ label: 'Contact Our Team', href: '/care' }}
    secondary={{ label: 'Plan Your Visit', href: '/plan-your-visit' }}
  />
</BaseLayout>

<style>
  .essentials-grid {
    gap: 1rem;
  }

  .essential-card {
    padding: 1.05rem;
    display: grid;
    gap: 0.6rem;
    border-top: 3px solid rgba(42, 111, 232, 0.55);
  }

  .essential-card p {
    color: #55647d;
  }
</style>
